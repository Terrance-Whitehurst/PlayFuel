# PlayFuel — Supabase Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── Supabase project ──────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key-from-supabase-dashboard>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-from-supabase-dashboard>

# ── Sign in with Apple ────────────────────────────────────────────────────────
# These match the values entered in Supabase Dashboard → Authentication → Providers → Apple
APPLE_SERVICE_ID=com.playfuel.app.auth
APPLE_TEAM_ID=<10-char-apple-team-id>
APPLE_KEY_ID=<10-char-key-id>
APPLE_PRIVATE_KEY_PATH=./AuthKey_<KEY_ID>.p8
APPLE_REDIRECT_URL=https://<project-ref>.supabase.co/auth/v1/callback

# ── Local Supabase CLI (supabase start) ───────────────────────────────────────
# These are the defaults for the local Supabase stack.
# Override only if you changed supabase/config.toml ports.
# SUPABASE_URL=http://localhost:54321
# SUPABASE_ANON_KEY=<local-anon-key printed by `supabase start`>
# SUPABASE_SERVICE_ROLE_KEY=<local-service-role-key printed by `supabase start`>
