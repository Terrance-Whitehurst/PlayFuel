# Local agent team config + session data — not part of the app
.pi/

# Claude Code agent state
.claude/

# Supabase CLI runtime cache
supabase/.temp/

# Xcode per-user UI state
xcuserdata/
*.xcuserstate

# Environment files — NEVER commit these (contain secrets)
# Real values go here locally; .env.example files contain placeholders only.
.env
**/.env

# Python bytecode / build cache
__pycache__/
*.pyc
*.pyo

# Swift Package Manager build cache
.build/
**/.build/
