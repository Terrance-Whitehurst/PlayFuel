# PlayFuel API — environment variables
# Copy to .env and fill in real values.
# NEVER commit .env to version control.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Service role key — loaded but NOT used for RLS-protected routes in MVP.
# Stored here so Phase 6 / admin scripts can use it safely server-side.
# Never pass this to a client or expose in logs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Places provider (Phase 5 / Task #8) ────────────────────────────────────
# PLACES_PROVIDER: auto | google | mock
#   auto   → Google if GOOGLE_PLACES_API_KEY is set, else MockPlacesProvider
#   google → always Google (key required)
#   mock   → MockPlacesProvider always (deterministic demo fixture; no key needed)
# For demo / local dev: leave PLACES_PROVIDER=mock and omit GOOGLE_PLACES_API_KEY.
PLACES_PROVIDER=auto
# Set your Google Places API key here (Places API New).
# Provision via: Google Cloud Console → APIs & Services → Credentials → Create API key
# Restrict key to 'Places API (New)' only.
# Fly secret: flyctl secrets set GOOGLE_PLACES_API_KEY=<your-key> --app playfuel-api
# NOTE: rotate after smoke test if key was shared in any chat / log.
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here
PLACES_SEARCH_RADIUS_M=4828
PLACES_MAX_RESULTS=6

# ─── LLM provider (Phase 6 / Task #9) ──────────────────────────────────────
# LLM_PROVIDER: auto | template | anthropic | openai
#   auto     → first provider with a key, else TemplateProvider
#   template → deterministic, no network, no API keys needed (demo default)
# For demo / local dev: leave LLM_PROVIDER=template; no keys required.
LLM_PROVIDER=template
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-v3
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=600
LLM_TEMPERATURE=0.3

# ─── Server ──────────────────────────────────────────────────────────────────
API_PORT=8000
