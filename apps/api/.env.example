# PlayFuel API — environment variables
# Copy to .env and fill in real values.
# NEVER commit .env to version control.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Service role key — loaded but NOT used for RLS-protected routes in MVP.
# Stored here so Phase 6 / admin scripts can use it safely server-side.
# Never pass this to a client or expose in logs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Server ──────────────────────────────────────────────────────────────────
API_PORT=8000
