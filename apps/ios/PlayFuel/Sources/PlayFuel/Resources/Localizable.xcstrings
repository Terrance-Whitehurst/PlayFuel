    },
    "General tournament-day reminders. Not medical, nutrition, or training advice. Talk to your coach, physician, or athletic trainer for anything specific to your child." : {
      "comment" : "A verbatim safety disclaimer footer that appears at the bottom of the expanded card sheet. It must not be removed or paraphrased.",
      "isCommentAutoGenerated" : true
    },
    "hardcoded.bag_food_fallback" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use immediate bag food only: banana, pretzels, applesauce pouch, electrolyte drink, simple sandwich if tolerated."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usa solo comida de bolsa inmediata: plátano, galletas tipo pretzel, compota de manzana en bolsita, bebida de electrolitos, sándwich sencillo si se tolera."
          }
        }
      }
    },
    "hardcoded.disclaimer" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app provides general tournament preparation guidance. It is not medical advice, nutrition therapy, or a substitute for a coach, physician, athletic trainer, or registered dietitian. For injuries, illness, heat symptoms, allergies, eating disorders, or medical conditions, consult a qualified professional."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta aplicación proporciona orientación general para la preparación de torneos. No es consejo médico, terapia nutricional ni un sustituto de un entrenador, médico, preparador físico o nutriólogo certificado. En caso de lesiones, enfermedad, síntomas de calor, alergias, trastornos alimenticios o condiciones médicas, consulta a un profesional calificado."
          }
        }
      }
    },
    "hardcoded.heat_cooldown_step" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Get them into the shade and offer cool water or an electrolyte drink before anything else."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Llévalos a la sombra y ofrece agua fría o una bebida con electrolitos antes que cualquier otra cosa."
          }
        }
      }
    },
    "hardcoded.heat_emergency" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If your player feels faint or confused, has chest pain, stops sweating in extreme heat, has severe cramps, vomits repeatedly, or shows signs of heat illness: stop play and seek medical help. Call 911 (or your local emergency number) in an emergency."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si tu jugador se siente mareado o confundido, tiene dolor en el pecho, deja de sudar con calor extremo, tiene calambres severos, vomita repetidamente o muestra señales de enfermedad por calor: detén el juego y busca ayuda médica. Llama al 911 (o al número de emergencias local) en caso de emergencia."
          }
        }
      }
    },
    "hardcoded.overrun" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Match 1 may not finish before Match 2's estimated start time. Alert the tournament desk."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es posible que el primer partido no termine antes de la hora de inicio estimada del segundo. Avisa en la mesa de registro del torneo."
          }
        }
      }
    },
